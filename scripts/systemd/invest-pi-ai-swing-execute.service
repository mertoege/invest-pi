[Unit]
Description=Invest-Pi · KI-Swing-Trader (Live-Paper) — Basket auf 2. Paper-Konto ausfuehren
After=network-online.target
OnFailure=invest-pi-error-alert@%n.service

[Service]
Type=oneshot
User=investpi
WorkingDirectory=/home/investpi/invest-pi
EnvironmentFile=/home/investpi/invest-pi/.env
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStart=/usr/bin/python3 -B scripts/ai_swing_execute.py
MemoryMax=1G
CPUQuota=30%
