[Unit]
Description=Invest-Pi · Autonomous Operator (Daily System Check + Auto-Fix)
After=network-online.target

[Service]
Type=oneshot
User=investpi
WorkingDirectory=/home/investpi/invest-pi
EnvironmentFile=/home/investpi/invest-pi/.env
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStart=/usr/bin/python3 -B scripts/autonomous_operator.py
MemoryMax=512M
CPUQuota=30%
