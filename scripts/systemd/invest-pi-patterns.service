[Unit]
Description=Invest-Pi · Pattern-Library Refresh (10y OHLCV → drawdown_events)

OnFailure=invest-pi-error-alert@%n.service
[Service]
Type=oneshot
User=investpi
WorkingDirectory=/home/investpi/invest-pi
EnvironmentFile=/home/investpi/invest-pi/.env
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStart=/usr/bin/python3 -B scripts/build_patterns.py --missing-only
MemoryMax=2G
CPUQuota=70%
TimeoutStartSec=30min
