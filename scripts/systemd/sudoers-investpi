# Erlaubt investpi-User das Synchronisieren von systemd-Files + daemon-reload
# fuer auto_pull.sh ohne Passwort. Alle anderen sudo-Aktionen weiterhin geschuetzt.
investpi ALL=(root) NOPASSWD: /bin/cp /home/investpi/invest-pi/scripts/systemd/* /etc/systemd/system/
investpi ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload
