[Unit]
Description=Invest-Pi · KI-Swing-Trader Outcome-Tracker (Forward-Returns + IC)
After=network-online.target

[Service]
Type=oneshot
User=investpi
WorkingDirectory=/home/investpi/invest-pi
EnvironmentFile=/home/investpi/invest-pi/.env
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStart=/usr/bin/python3 -B scripts/ai_swing_outcomes.py
MemoryMax=1G
CPUQuota=30%
