# ────────────────────────────────────────────────────────────
# Invest-Pi · Environment-Variablen
# Diese Datei wird beim Pi-Setup nach .env kopiert.
# .env ist in .gitignore — niemals committen.
# ────────────────────────────────────────────────────────────

# === Alpaca Paper Trading (REQUIRED für Live-Demo) =========
# Anlegen: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_API_SECRET=

# === Anthropic API (REQUIRED für Phase 3+ Sonnet/Opus-Calls) =
ANTHROPIC_API_KEY=

# === Telegram Bot (REQUIRED für Phase 3 Notifications) =====
# Bot anlegen via @BotFather, chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Optional (Phase 4+) ===================================
# FINNHUB_API_KEY=
# NEWSAPI_KEY=

# === Paths (vom Setup-Skript gesetzt — nicht ändern) =======
INVEST_PI_DATA_DIR=/home/investpi/invest-pi/data
